{
  "name": "@lxg2it/ai",
  "version": "0.1.0",
  "description": "TypeScript SDK for the Model Router — typed routing tiers, streaming with reasoning, tool execution loops, and Vercel AI SDK integration",
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./vercel": {
      "import": "./dist/vercel.js",
      "types": "./dist/vercel.d.ts"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src tests"
  },
  "keywords": [
    "ai",
    "llm",
    "model-router",
    "openai",
    "anthropic",
    "sdk",
    "routing",
    "streaming"
  ],
  "author": "lxg2it",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/lxg2it/ai-sdk"
  },
  "homepage": "https://api.lxg2it.com",
  "peerDependencies": {
    "ai": ">=4.0.0",
    "openai": ">=4.0.0",
    "zod": ">=3.0.0"
  },
  "peerDependenciesMeta": {
    "zod": {
      "optional": true
    },
    "ai": {
      "optional": true
    }
  },
  "dependencies": {
    "zod-to-json-schema": "^3.24.1"
  },
  "vitest": {
    "environment": "node",
    "include": ["tests/**/*.test.ts"],
    "coverage": {
      "provider": "v8",
      "include": ["src/**"],
      "exclude": ["src/index.ts"]
    }
  },

  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^20.0.0",
    "@typescript-eslint/eslint-plugin": "^8.57.0",
    "@typescript-eslint/parser": "^8.57.0",
    "@vitest/coverage-v8": "^4.1.0",
    "ai": "^4.0.0",
    "eslint": "^9.39.4",
    "openai": "^4.85.0",
    "typescript": "^5.4.0",
    "typescript-eslint": "^8.57.0",
    "vitest": "^3.2.4",
    "zod": "^3.24.0"
  }
}
